#!/usr/bin/env php
<?php

declare(strict_types=1);

use CarePassport\Database\Connection;

$config = require dirname(__DIR__) . '/bootstrap/app.php';
$args = array_slice($argv, 1);
$action = $args[0] ?? 'create';

const SAMPLE_EMAIL = 'sample.passport@example.test';
const SAMPLE_PASSWORD = 'SamplePass123!';
const SAMPLE_PHOTO_PATH = 'storage/app/sample-passport/ellie-hart-portrait.jpg';

if (in_array('--help', $args, true) || in_array('-h', $args, true)) {
    echo "Usage: php bin/sample-passport [create|remove]\n";
    echo "\n";
    echo "Creates or removes one development-only fictional sample passport.\n";
    echo "Create is allowed only when APP_ENV is local, development or testing.\n";
    exit(0);
}

if (! in_array($action, ['create', 'remove'], true)) {
    echo "Usage: php bin/sample-passport [create|remove]\n";
    exit(1);
}

$appEnv = strtolower((string) ($config['app']['env'] ?? 'production'));

if ($action === 'create' && ! in_array($appEnv, ['local', 'development', 'testing'], true)) {
    fwrite(STDERR, "Refusing to create sample data when APP_ENV={$appEnv}.\n");
    fwrite(STDERR, "Set APP_ENV=local, development or testing for development sample data.\n");
    exit(1);
}

$pdo = Connection::make($config['database']);

if ($action === 'remove') {
    $removed = removeSamplePassport($pdo);
    echo "Removed sample passport data.\n";
    echo "Users removed: {$removed['users']}\n";
    echo "Residents removed: {$removed['residents']}\n";
    exit(0);
}

$removed = removeSamplePassport($pdo);
$sample = createSamplePassport($pdo);
writeSamplePhoto();

echo "Created development sample passport.\n";

if ($removed['users'] > 0 || $removed['residents'] > 0) {
    echo "Previous sample data was replaced.\n";
}

echo "Login email: " . SAMPLE_EMAIL . "\n";
echo "Login password: " . SAMPLE_PASSWORD . "\n";
echo "Resident: {$sample['resident_name']}\n";
echo "Open the app, log in, then use the dashboard or /output.\n";

/**
 * @return array{users:int,residents:int}
 */
function removeSamplePassport(PDO $pdo): array
{
    $userStatement = $pdo->prepare('SELECT id FROM users WHERE email = :email LIMIT 1');
    $userStatement->execute(['email' => SAMPLE_EMAIL]);
    $userId = $userStatement->fetchColumn();

    if ($userId === false) {
        removeSamplePhoto();

        return [
            'users' => 0,
            'residents' => 0,
        ];
    }

    $residentDelete = $pdo->prepare('DELETE FROM residents WHERE user_id = :user_id');
    $residentDelete->execute(['user_id' => (int) $userId]);
    $residents = $residentDelete->rowCount();

    $userDelete = $pdo->prepare('DELETE FROM users WHERE id = :id');
    $userDelete->execute(['id' => (int) $userId]);

    removeSamplePhoto();

    return [
        'users' => $userDelete->rowCount(),
        'residents' => $residents,
    ];
}

/**
 * @return array{resident_name:string}
 */
function createSamplePassport(PDO $pdo): array
{
    $pdo->beginTransaction();

    try {
        $userId = createSampleUser($pdo);
        $residentId = createSampleResident($pdo, $userId);
        createSampleConsent($pdo, $residentId);
        createSamplePhotoRow($pdo, $residentId);
        createSampleAnswers($pdo, $residentId);
        $pdo->commit();

        return ['resident_name' => 'Eleanor Hart'];
    } catch (Throwable $exception) {
        $pdo->rollBack();

        throw $exception;
    }
}

function createSampleUser(PDO $pdo): int
{
    $statement = $pdo->prepare(
        'INSERT INTO users (name, email, password_hash)
        VALUES (:name, :email, :password_hash)',
    );
    $statement->execute([
        'name' => 'Development Sample User',
        'email' => SAMPLE_EMAIL,
        'password_hash' => password_hash(SAMPLE_PASSWORD, PASSWORD_DEFAULT),
    ]);

    return (int) $pdo->lastInsertId();
}

function createSampleResident(PDO $pdo, int $userId): int
{
    $pathId = requiredId($pdo, 'SELECT id FROM question_paths WHERE slug = :slug LIMIT 1', ['slug' => 'full_37'], 'Full 37 question path');
    $statement = $pdo->prepare(
        'INSERT INTO residents (
            user_id,
            full_name,
            preferred_name,
            support_context,
            service_location_name,
            location_reference,
            primary_supporter_name,
            notes,
            question_path_id
        ) VALUES (
            :user_id,
            :full_name,
            :preferred_name,
            :support_context,
            :service_location_name,
            :location_reference,
            :primary_supporter_name,
            :notes,
            :question_path_id
        )',
    );
    $statement->execute([
        'user_id' => $userId,
        'full_name' => 'Eleanor Hart',
        'preferred_name' => 'Ellie',
        'support_context' => 'home_care',
        'service_location_name' => 'Development sample support setting',
        'location_reference' => 'Sample room or visit reference',
        'primary_supporter_name' => 'Maya Hart',
        'notes' => 'DEVELOPMENT SAMPLE DATA - fictional passport for local preview testing.',
        'question_path_id' => $pathId,
    ]);

    return (int) $pdo->lastInsertId();
}

function createSampleConsent(PDO $pdo, int $residentId): void
{
    $modeId = requiredId($pdo, 'SELECT id FROM completion_modes WHERE slug = :slug LIMIT 1', ['slug' => 'assisted'], 'assisted completion mode');
    $statement = $pdo->prepare(
        'INSERT INTO consent_records (
            resident_id,
            completion_mode_id,
            helper_name,
            helper_relationship,
            acknowledgement_data,
            consent_acknowledged_at,
            consent_text_version
        ) VALUES (
            :resident_id,
            :completion_mode_id,
            :helper_name,
            :helper_relationship,
            :acknowledgement_data,
            NOW(),
            :consent_text_version
        )',
    );
    $statement->execute([
        'resident_id' => $residentId,
        'completion_mode_id' => $modeId,
        'helper_name' => 'Maya Hart',
        'helper_relationship' => 'Daughter',
        'acknowledgement_data' => json_encode([
            'development_sample' => true,
            'privacy_acknowledged' => true,
            'fictional_data' => true,
        ], JSON_THROW_ON_ERROR),
        'consent_text_version' => 'development-sample-v1',
    ]);
}

function createSamplePhotoRow(PDO $pdo, int $residentId): void
{
    $statement = $pdo->prepare(
        'INSERT INTO photos (resident_id, type, original_file_path, processed_file_path, caption)
        VALUES (:resident_id, :type, :original_file_path, :processed_file_path, :caption)',
    );
    $statement->execute([
        'resident_id' => $residentId,
        'type' => 'portrait',
        'original_file_path' => SAMPLE_PHOTO_PATH,
        'processed_file_path' => SAMPLE_PHOTO_PATH,
        'caption' => 'Development sample portrait',
    ]);
}

function createSampleAnswers(PDO $pdo, int $residentId): void
{
    $questionStatement = $pdo->prepare('SELECT id FROM questions WHERE canonical_number = :number LIMIT 1');
    $answerStatement = $pdo->prepare(
        'INSERT INTO answers (resident_id, question_id, answer_text, skipped, visibility)
        VALUES (:resident_id, :question_id, :answer_text, :skipped, :visibility)',
    );

    foreach (sampleAnswers() as $answer) {
        $questionStatement->execute(['number' => $answer['number']]);
        $questionId = $questionStatement->fetchColumn();

        if ($questionId === false) {
            throw new RuntimeException('Missing question number ' . $answer['number'] . '. Run migrations and seeds first.');
        }

        $answerStatement->execute([
            'resident_id' => $residentId,
            'question_id' => (int) $questionId,
            'answer_text' => $answer['text'],
            'skipped' => $answer['skipped'] ? 1 : 0,
            'visibility' => $answer['visibility'],
        ]);
    }
}

