/**
 * @param array<string,mixed> $params
 */
function requiredId(PDO $pdo, string $sql, array $params, string $label): int
{
    $statement = $pdo->prepare($sql);
    $statement->execute($params);
    $id = $statement->fetchColumn();

    if ($id === false) {
        throw new RuntimeException('Missing ' . $label . '. Run php bin/migrate and php bin/seed first.');
    }

    return (int) $id;
}

function writeSamplePhoto(): void
{
    $path = base_path(SAMPLE_PHOTO_PATH);
    $directory = dirname($path);

    if (! is_dir($directory) && ! mkdir($directory, 0775, true) && ! is_dir($directory)) {
        throw new RuntimeException('Unable to create sample photo directory: ' . $directory);
    }

    $jpeg = '';

    if (file_put_contents($path, base64_decode($jpeg, true)) === false) {
        throw new RuntimeException('Unable to write sample photo: ' . $path);
    }
}

function removeSamplePhoto(): void
{
    $path = base_path(SAMPLE_PHOTO_PATH);

    if (is_file($path)) {
        @unlink($path);
    }

    $directory = dirname($path);

    if (is_dir($directory)) {
        @rmdir($directory);
    }
}
